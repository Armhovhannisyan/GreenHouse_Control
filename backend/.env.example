# eWeLink OAuth (recommended) — from https://dev.ewelink.cc/ App Management
# Redirect URL in the developer console must match EWELINK_OAUTH_REDIRECT_URL exactly.
EWELINK_APP_ID=
EWELINK_APP_SECRET=
EWELINK_OAUTH_REDIRECT_URL=http://localhost:3001/api/sonoff/oauth/callback

# eWeLink legacy (optional fallback) — often blocked by CoolKit; prefer OAuth above
EWELINK_EMAIL=
EWELINK_PASSWORD=
EWELINK_REGION=eu
